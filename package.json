{
  "name": "@byterover/umami-mcp",
  "version": "0.1.0",
  "description": "A minimal, read-only Model Context Protocol server for Umami analytics (Cloud or self-hosted).",
  "license": "Elastic-2.0",
  "type": "module",
  "bin": {
    "umami-mcp": "./dist/index.js"
  },
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.build.json --noEmit",
    "test": "vitest run",
    "lint": "biome check .",
    "format": "biome format --write .",
    "start": "node dist/index.js",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.5",
    "@types/node": "22.10.5",
    "typescript": "5.7.3",
    "vitest": "2.1.8"
  },
  "keywords": [
    "umami",
    "analytics",
    "mcp",
    "model-context-protocol",
    "byterover",
    "grove"
  ]
}
