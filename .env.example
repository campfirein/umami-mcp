# Umami MCP configuration. Pick ONE of the two modes.

# --- Umami Cloud (cloud.umami.is) ---------------------------------------
# An API key from https://cloud.umami.is (Settings → API keys). Read-only.
UMAMI_API_KEY=

# --- Self-hosted Umami --------------------------------------------------
# Your instance's base URL, plus a username/password to mint a token.
# UMAMI_API_URL=https://umami.example.com
# UMAMI_USERNAME=
# UMAMI_PASSWORD=

# --- Advanced (rarely needed) -------------------------------------------
# Override the API base URL (Cloud default: https://api.umami.is) and the
# path prefix (Cloud default: /v1, self-hosted default: /api).
# UMAMI_API_URL=
# UMAMI_API_PATH=
